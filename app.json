{
  "expo": {
    "name": "Baiboly Quiz",
    "slug": "baiboly-quiz-app",
    "scheme": "baibolyquiz",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/logo/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hasindrae.baibolyquizapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/logo/logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.hasindrae.baibolyquizapp"
    },
    "web": {
      "favicon": "./assets/logo/logo.png"
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      "expo-sqlite",
      "expo-sharing",
      "expo-av"
    ],
    "extra": {
      "eas": {
        "projectId": "4abbd82d-030f-48c8-bbf0-f972f9fcffc4"
      }
    },
    "owner": "hasindrae"
  }
}
